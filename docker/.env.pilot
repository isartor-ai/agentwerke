# Agentwerke pilot test stack — environment template
# Copy this file to .env.pilot.local and fill in values before starting the stack.
#
#   cp docker/.env.pilot docker/.env.pilot.local
#   docker compose -f docker/docker-compose.pilot.yml --env-file docker/.env.pilot.local up --build

# ── Scenario D only ──────────────────────────────────────────────────────────
# Set your Anthropic API key to enable real LLM calls (Scenario D).
# Leave blank to use NullLanguageModelClient — the run will fail with a clear
# "no API key configured" message, which is the graceful-degradation scenario.
ANTHROPIC__APIKEY=
