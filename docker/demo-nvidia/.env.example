# Copy to docker/demo-nvidia/.env and fill in real values.
# Never commit docker/demo-nvidia/.env.

# NVIDIA API catalog key for https://integrate.api.nvidia.com/v1.
NVIDIA_API_KEY=nvapi-replace-me

# LiteLLM master key used by Agentwerke as Anthropic__ApiKey.
# Keep these two values identical.
LITELLM_MASTER_KEY=sk-agentwerke-demo-local-change-me
Anthropic__ApiKey=sk-agentwerke-demo-local-change-me

# GitHub token with access to isartor-ai/agentwerke-demo.
# Classic PAT scopes: repo. Fine-grained token permissions: Contents read/write,
# Issues read/write, Pull requests read/write, Metadata read.
Integrations__GitHub__PersonalAccessToken=github_pat_replace_me

# Shared webhook secret used by GitHub and Agentwerke.
Integrations__GitHub__WebhookSecret=replace-with-a-long-random-string
