{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=autofac_dev;Username=postgres;Password=postgres"
  },
  "Storage": {
    "Provider": "filesystem",
    "S3": {
      "BucketName": "",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": true
    },
    "RootPath": "./storage-dev"
  },
  "Policies": {
    "FilePath": "./policies/policies.development.yaml"
  },
  "Jwt": {
    "DevIdentityEnabled": true,
    "DevIdentitySubject": "dev:admin",
    "DevIdentityRoles": [ "Admin" ]
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Sandboxes": {
    "Enabled": false,
    "Provider": "docker",
    "Docker": {
      "Enabled": false,
      "DefaultImage": "alpine:3.19",
      "TimeoutSeconds": 60,
      "MemoryLimitMb": 256,
      "CpuQuota": 50000,
      "ArtifactsHostPath": "",
      "DockerEndpoint": "unix:///var/run/docker.sock"
    },
    "OpenSandbox": {
      "Enabled": false,
      "BaseUrl": "http://localhost:8080/v1",
      "ApiKey": "",
      "DefaultImage": "alpine:3.19",
      "DefaultTimeoutSeconds": 60,
      "ReadinessTimeoutSeconds": 30,
      "DefaultMemoryLimitMb": 256,
      "DefaultCpuMilliCores": 500,
      "UseServerProxy": false,
      "WorkingDirectory": "/workspace",
      "DefaultArtifactPaths": [ "/output" ]
    },
    "KubernetesKata": {
      "Enabled": false,
      "RuntimeClassName": "kata",
      "Namespace": "default",
      "DefaultImage": "alpine:3.19"
    }
  },
  "Integrations": {
    "Jira": {
      "Enabled": false,
      "ApiBaseUrl": "https://your-domain.atlassian.net/",
      "Username": "",
      "ApiToken": "",
      "WebhookSecret": "",
      "TriggerEvents": [ "jira:issue_created" ]
    },
    "GitHub": {
      "Enabled": false,
      "WebhookSecret": "",
      "TriggerActions": [ "opened" ],
      "ApiBaseUrl": "https://api.github.com/",
      "RepositoryOwner": "",
      "RepositoryName": "",
      "PersonalAccessToken": "",
      "DefaultBaseBranch": "main",
      "BranchPrefix": "autofac/run-",
      "CreateDraftPullRequests": true
    },
    "Slack": {
      "Enabled": false,
      "WebhookUrl": ""
    },
    "Teams": {
      "Enabled": false,
      "WebhookUrl": ""
    }
  },
  "Agents": {
    "Registry": {
      "AgentsDirectory": "./agents"
    }
  },
  "Camunda": {
    "Enabled": true,
    "BaseUrl": "http://localhost:8088/",
    "AuthMode": "None",
    "Username": "",
    "Password": "",
    "BearerToken": "",
    "TimeoutSeconds": 10
  }
}
