{
  "ConnectionStrings": {
    "Postgres": "Host=localhost;Port=5432;Database=autofac;Username=postgres;Password=postgres"
  },
  "Storage": {
    "Provider": "filesystem",
    "S3": {
      "BucketName": "",
      "Region": "us-east-1",
      "ServiceUrl": "",
      "AccessKey": "",
      "SecretKey": "",
      "ForcePathStyle": true
    },
    "RootPath": "./storage"
  },
  "Policies": {
    "FilePath": "./policies/policies.yaml"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "Tracing": {
    "OtlpEndpoint": "",
    "ServiceName": "autofac-api",
    "ServiceVersion": "1.0.0"
  },
  "Sandboxes": {
    "Docker": {
      "Enabled": false,
      "DefaultImage": "alpine:3.19",
      "TimeoutSeconds": 60,
      "MemoryLimitMb": 256,
      "CpuQuota": 50000,
      "ArtifactsHostPath": "",
      "DockerEndpoint": "unix:///var/run/docker.sock"
    }
  },
  "Agents": {
    "Skills": {
      "SkillsDirectory": ""
    }
  },
  "Integrations": {
    "Jira": {
      "Enabled": false,
      "ApiBaseUrl": "https://your-domain.atlassian.net/",
      "Username": "",
      "ApiToken": "",
      "WebhookSecret": "",
      "TriggerEvents": [ "jira:issue_created" ]
    },
    "GitHub": {
      "Enabled": false,
      "WebhookSecret": "",
      "TriggerActions": [ "opened" ],
      "ApiBaseUrl": "https://api.github.com/",
      "RepositoryOwner": "",
      "RepositoryName": "",
      "PersonalAccessToken": "",
      "DefaultBaseBranch": "main",
      "BranchPrefix": "autofac/run-",
      "CreateDraftPullRequests": true
    },
    "Slack": {
      "Enabled": false,
      "WebhookUrl": ""
    },
    "Teams": {
      "Enabled": false,
      "WebhookUrl": ""
    }
  },
  "Camunda": {
    "Enabled": false,
    "BaseUrl": "http://localhost:8088/",
    "AuthMode": "None",
    "Username": "",
    "Password": "",
    "BearerToken": "",
    "TimeoutSeconds": 10
  }
}
